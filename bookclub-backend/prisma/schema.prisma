generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Book {
  id           String         @id @default(uuid())
  isbn         String?
  name         String?
  author       String?
  year         Int?
  pages        Int?
  comment      String?
  language     String?
  genre        String?
  user_id      String?
  user         User?          @relation(fields: [user_id], references: [id])
  BookProposed BookProposed[]
  BookSaved    BookSaved[]
  BookVoted    BookVoted[]
}

model BookClub {
  id              String            @id @default(uuid())
  name            String            @unique
  invite_code     String?           @unique
  status          Int?
  owner_id        String?
  User            User?             @relation(fields: [owner_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  BookClubMembers BookClubMembers[]
  BookProposed    BookProposed[]
  BookVoted       BookVoted[]
  Invite          Invite[]
  Cycle          Cycle[]
}

model BookClubMembers {
  id          String    @id @default(uuid())
  user_id     String?
  user_role   Int?
  bookclub_id String?
  BookClub    BookClub? @relation(fields: [bookclub_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  User        User?     @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model BookVoted {
  id           String        @id @default(uuid())
  proposal_id  String?
  user_id      String?
  weight       Int?
  BookProposed BookProposed? @relation(fields: [proposal_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  User         User?         @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  book         Book?         @relation(fields: [bookId], references: [id])
  bookId       String?
  bookClub     BookClub?     @relation(fields: [bookClubId], references: [id])
  bookClubId   String?
}

model BookProposed {
  id         String      @id @default(uuid())
  book_id    String?
  cycle_id   String?
  user_id    String?
  Book       Book?       @relation(fields: [book_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  Cycle      Cycle?      @relation(fields: [cycle_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  User       User?       @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  bookClub   BookClub?   @relation(fields: [bookClubId], references: [id])
  bookClubId String?
  bookVoteds BookVoted[]
}

model Cycle {
  id            String         @id @default(uuid())
  bookclub_id   String?
  createdAt     DateTime?      @default(now())
  proposalEnd   DateTime?
  votingEnd     DateTime?
  BookClub      BookClub?      @relation(fields: [bookclub_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  bookProposeds BookProposed[]
}

model BookSaved {
  id      String  @id @default(uuid())
  user_id String?
  book_id String?
  Book    Book?   @relation(fields: [book_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  User    User?   @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model Invite {
  id          String    @id @default(uuid())
  bookclub_id String?
  invite_code String?
  BookClub    BookClub? @relation(fields: [bookclub_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model User {
  id              String            @id @default(uuid())
  email           String            @unique
  name            String            @unique
  password_hash   String
  BookClub        BookClub[]
  BookClubMembers BookClubMembers[]
  BookSaved       BookSaved[]
  BookVoted       BookVoted[]
  Books           Book[]
  bookProposeds   BookProposed[]
}
